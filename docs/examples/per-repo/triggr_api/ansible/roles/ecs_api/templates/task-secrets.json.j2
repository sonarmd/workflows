{# Secrets for ECS task definition — merged into the 'environment' array.
   NOT using ECS 'secrets' field (that requires AWS Secrets Manager / SSM).
   These are injected as plaintext env vars into the container.
   generate-config.js reads them at startup to build configuration.json.

   For Ansible provisioning: values come from Ansible Vault.
   For GHA deploys: values come from 1Password via load-secrets action.
#}
[
  {"name": "MONGO_PASSWORD",                          "value": "{{ mongo_password }}"},
  {"name": "MONGO_READ_ONLY_PASSWORD",                "value": "{{ mongo_read_only_password | default('') }}"},
  {"name": "SESSION_SECRET",                          "value": "{{ session_secret }}"},
  {"name": "JWT_SECRET",                              "value": "{{ jwt_secret }}"},
  {"name": "FIREBASE_SERVER_KEY",                     "value": "{{ firebase_server_key | default('') }}"},
  {"name": "GITHUB_OAUTH_SECRET",                     "value": "{{ github_secret | default('') }}"},
  {"name": "GCAL_CLIENT_SECRET",                      "value": "{{ gcal_client_secret | default('') }}"},
  {"name": "GCAL_REFRESH_TOKEN",                      "value": "{{ gcal_refresh_token | default('') }}"},
  {"name": "BRITEVERIFY_API_KEY",                     "value": "{{ briteverify_api_key | default('') }}"},
  {"name": "CHANGE_HEALTHCARE_CLIENT_ID",             "value": "{{ change_healthcare_client_id | default('') }}"},
  {"name": "CHANGE_HEALTHCARE_CLIENT_SECRET",         "value": "{{ change_healthcare_client_secret | default('') }}"},
  {"name": "ITERABLE_API_KEY",                        "value": "{{ iterable_api_key | default('') }}"},
  {"name": "ITERABLE_WEBHOOK_PASSWORD",               "value": "{{ webhookPassword | default('') }}"},
  {"name": "MIXPANEL_MOBILE_API_SECRET",              "value": "{{ mixpanel_mobile_api_secret | default('') }}"},
  {"name": "MIXPANEL_MOBILE_TOKEN",                   "value": "{{ mixpanel_mobile_token | default('') }}"},
  {"name": "PAGERDUTY_KEY_LOW_PRIORITY",              "value": "{{ eng_pager_duty_key_low_priority | default('') }}"},
  {"name": "PAGERDUTY_KEY_HIGH_PRIORITY",             "value": "{{ eng_pager_duty_key_high_priority | default('') }}"},
  {"name": "REDIS_AUTH_TOKEN",                        "value": "{{ redis_auth_token | default('') }}"},
  {"name": "SENDGRID_API_KEY",                        "value": "{{ sendgrid_api_key | default('') }}"},
  {"name": "SLACK_BOT_TOKEN",                         "value": "{{ slack_bot_token | default('') }}"},
  {"name": "SLACK_COMMUNITY_WEBHOOK_VERIFICATION_TOKEN", "value": "{{ slack_community_webhook_verification_token | default('') }}"},
  {"name": "SLACK_CLAIMS_WEBHOOK",                    "value": "{{ claims_webhook | default('') }}"},
  {"name": "SLACK_UNDELIVERABLE_EMAIL_ALERTS_WEBHOOK", "value": "{{ undeliverable_email_alerts_webhook | default('') }}"},
  {"name": "SLACK_UNDELIVERABLE_MESSAGE_ALERTS_WEBHOOK_URL", "value": "{{ undeliverable_message_alerts_webhook_url | default('') }}"},
  {"name": "TWILIO_AUTH_TOKEN",                       "value": "{{ twilio_auth_token | default('') }}"},
  {"name": "TWILIO_API_KEY",                          "value": "{{ twilio_api_key | default('') }}"},
  {"name": "TWILIO_API_SECRET",                       "value": "{{ twilio_api_secret | default('') }}"},
  {"name": "TWILIO_OUTGOING_PHONE_NUMBER",            "value": "{{ twilio_outgoing_phone_number | default('') }}"},
  {"name": "TWILIO_DEFAULT_SMS_PHONE_NUMBER",         "value": "{{ twilio_default_sms_phone_number | default('') }}"},
  {"name": "TWILIO_OUTBOUND_PHONE_NUMBERS",           "value": "{{ twilio_outbound_phone_numbers | default([]) | to_json }}"},
  {"name": "TWILIO_IVR_FLOW_SID",                     "value": "{{ twilio_ivr_flow_sid | default('') }}"},
  {"name": "TWILIO_VOICE_APP_SID",                    "value": "{{ twilio_voice_app_sid | default('') }}"}
]
