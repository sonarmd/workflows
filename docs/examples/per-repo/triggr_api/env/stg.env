# triggr_api — STG environment variables
# Maps to generate-config.js env var names
#
# Source: triggr_misc/Ansible/group_vars/tag_Group_Staging/vars.yml
#         triggr_misc/Ansible/group_vars/tag_InstanceType_APIStaging/vars.yml
#         triggr_misc/Ansible/roles/triggr_api/defaults/main.yml
#
# Lines marked SECRET are in Ansible Vault (secrets.yml).
# Migrate them to 1Password vault: smd_cicd_stg

# ── Environment ──────────────────────────────────────────────
DEPLOY_ENV=stg
ENVIRONMENT_NAME=Staging
SERVER_TYPE=Server
# DEPLOY_TAG is set at deploy time (git SHA or image tag)

# ── URLs ─────────────────────────────────────────────────────
API_PROTOCOL=https://
API_URL=api.stg.sonarmd.com
BASE_URL=stg.sonarmd.com
PROVIDER_URL=care.stg.sonarmd.com
ADMIN_URL=admin.stg.sonarmd.com
APP_INSTALL_URL=online.stg.sonarmd.com/?directInstall=true
SEAT_URL=seat.stg.sonarmd.com
SEAT_SIMULATOR_URL=guideprogram.stg.sonarmd.com
PATIENT_PORTAL_URL=my.stg.sonarmd.com
WEBSITE_URL=stg.una.app
EXTRA_ALLOWED_HOSTS=["ra-next.stg.sonarmd.com"]

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://sonarmdstaging.9rykd.mongodb.net/sonarmd?retryWrites=true&w=majority&appName=SonarMDStaging
MONGO_URL=sonarmdstaging.9rykd.mongodb.net
MONGO_PREFIX=mongodb+srv://
MONGO_USERNAME=api
#MONGO_PASSWORD=                    # SECRET: Ansible Vault
MONGO_READ_ONLY_URI=mongodb+srv://sonarmdstaging.9rykd.mongodb.net/sonarmd?retryWrites=true&w=majority&appName=SonarMDStaging
MONGO_READ_ONLY_USERNAME=readOnlyJobs
#MONGO_READ_ONLY_PASSWORD=          # SECRET: Ansible Vault
CHANGE_STREAMS_ENABLED=false

# ── Client Flags ─────────────────────────────────────────────
CLIENT_ASSET_BASE_URL=https://davl0j05hwdm0.cloudfront.net
CLIENT_RA_PHONE_NUMBER=773-809-3573

# ── Special IDs ──────────────────────────────────────────────
DIRECT_TO_CONSUMER_ID=5786b1987f313cc741548907
GROWTH_ID=58bee2d1a0f6e138cd664ac0
DEFAULT_MESSAGING_PERSONALITY_ID=59d2ac76eeb7bd0d9c1c6317

