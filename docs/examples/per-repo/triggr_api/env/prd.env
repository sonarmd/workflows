# ── Jobs ─────────────────────────────────────────────────────
SANITY_CHECK_THRESHOLD=0.5
DOCUMENT_VALIDATION_COUNT=2000

# ── ML ───────────────────────────────────────────────────────
ML_SERVER_URL=http://ml-server-prd.triggr.co
ML_SERVER_PREDICTION_MODE=local

# ── Mixpanel ─────────────────────────────────────────────────
#MIXPANEL_MOBILE_API_SECRET=         # SECRET: Ansible Vault
#MIXPANEL_MOBILE_TOKEN=              # SECRET: Ansible Vault

# ── Mongoose ─────────────────────────────────────────────────
MONGOOSE_AUTO_INDEX=true

# ── PagerDuty ────────────────────────────────────────────────
#PAGERDUTY_KEY_LOW_PRIORITY=         # SECRET: Ansible Vault
#PAGERDUTY_KEY_HIGH_PRIORITY=        # SECRET: Ansible Vault

# ── Reports ──────────────────────────────────────────────────
REPORTS_S3_BUCKET=doc-storage-reports-prod
REPORTS_ENABLED=true
REPORTS_SIGNED_URL_EXPIRES=259200

# ── Redis ────────────────────────────────────────────────────
REDIS_ENABLED=true
#REDIS_AUTH_TOKEN=                   # SECRET: Ansible Vault
REDIS_ENDPOINT=master.apielasticacheprd.rstg5e.use2.cache.amazonaws.com

# ── SageMaker ────────────────────────────────────────────────
SAGEMAKER_ENROLLMENT_ENDPOINT=xgboost-2022-08-31-04-51-51-954

# ── SendGrid ─────────────────────────────────────────────────
#SENDGRID_API_KEY=                   # SECRET: Ansible Vault

# ── SFTP ─────────────────────────────────────────────────────
SFTP_ENABLED=false
SFTP_USERS=[]
# Note: prd has ftp_enabled=true with users in secrets.yml, but SFTP only
# activates for the FTP server role. In ECS there is no FTP role — use a
# dedicated container if SFTP is needed.

