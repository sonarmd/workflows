# triggr_api — PRD environment variables
# Maps to generate-config.js env var names
#
# Source: triggr_misc/Ansible/group_vars/tag_Group_Production/vars.yml
#         triggr_misc/Ansible/group_vars/tag_InstanceType_APIProduction/vars.yml
#         triggr_misc/Ansible/roles/triggr_api/defaults/main.yml
#
# Lines marked SECRET are in Ansible Vault (secrets.yml).
# Migrate them to 1Password vault: smd_cicd_prd

# ── Environment ──────────────────────────────────────────────
DEPLOY_ENV=prd
ENVIRONMENT_NAME=Production
SERVER_TYPE=Server
# DEPLOY_TAG is set at deploy time (git SHA or image tag)

# ── URLs ─────────────────────────────────────────────────────
API_PROTOCOL=https://
API_URL=api.sonarmd.com
BASE_URL=sonarmd.com
PROVIDER_URL=care.sonarmd.com
ADMIN_URL=admin.sonarmd.com
APP_INSTALL_URL=online.sonarmd.com/?directInstall=true
SEAT_URL=seat.sonarmd.com
SEAT_SIMULATOR_URL=guideprogram.sonarmd.com
PATIENT_PORTAL_URL=my.sonarmd.com
WEBSITE_URL=una.app
EXTRA_ALLOWED_HOSTS=["ra-next.sonarmd.com"]

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://sonarmdproduction.5pges.mongodb.net/sonarmd?retryWrites=true&w=majority&appName=SonarMDProduction
MONGO_URL=sonarmdproduction.5pges.mongodb.net
MONGO_PREFIX=mongodb+srv://
MONGO_USERNAME=api
#MONGO_PASSWORD=                    # SECRET: Ansible Vault
MONGO_READ_ONLY_URI=mongodb+srv://sonarmdproduction.5pges.mongodb.net/sonarmd?retryWrites=true&w=majority&appName=SonarMDProduction
MONGO_READ_ONLY_USERNAME=readOnlyJobs
#MONGO_READ_ONLY_PASSWORD=          # SECRET: Ansible Vault
CHANGE_STREAMS_ENABLED=true

# ── Client Flags ─────────────────────────────────────────────
CLIENT_ASSET_BASE_URL=https://d1mgikdubop13m.cloudfront.net
CLIENT_RA_PHONE_NUMBER=773-809-3573

# ── Special IDs ──────────────────────────────────────────────
DIRECT_TO_CONSUMER_ID=57a5052b7220d5065b98e0f4
GROWTH_ID=58c6f32fdddfbb4b02e76b80
DEFAULT_MESSAGING_PERSONALITY_ID=59ca900587896b0498d202e7

# ── Auth ─────────────────────────────────────────────────────
#SESSION_SECRET=                     # SECRET: Ansible Vault
#JWT_SECRET=                         # SECRET: Ansible Vault

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_ENABLED=true
#FIREBASE_SERVER_KEY=                # SECRET: Ansible Vault
FIREBASE_SENDER_ID=428166452051

# ── GitHub OAuth ─────────────────────────────────────────────
GITHUB_OAUTH_ID=d32b6ef95e92c5e29e60
#GITHUB_OAUTH_SECRET=                # SECRET: Ansible Vault

# ── Google Analytics ─────────────────────────────────────────
GOOGLE_ANALYTICS_PROPERTY_ID=UA-81895025-3

# ── Google Calendar ──────────────────────────────────────────
GCAL_CLIENT_ID=428166452051-7u0k7bf52jduk9ai39qbgv6fmct1o9si.apps.googleusercontent.com
#GCAL_CLIENT_SECRET=                 # SECRET: Ansible Vault
GCAL_DEFAULT_INVITEES=["ppt-call@triggrhealth.com"]
GCAL_CALLS_CALENDAR_ID=triggrhealth.com_emtq69uh9om2jtmk0odljk8jic@group.calendar.google.com
#GCAL_REFRESH_TOKEN=                 # SECRET: Ansible Vault

# ── Images ───────────────────────────────────────────────────
IMAGES_ENABLE_RESIZING=false
IMAGES_S3_BUCKET=images.sonarmd.com

# ── BriteVerify ──────────────────────────────────────────────
