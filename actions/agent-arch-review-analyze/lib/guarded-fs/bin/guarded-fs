#!/usr/bin/env python3
"""guarded-fs CLI launcher.

Prepends the package root to sys.path so the script works when invoked
from anywhere (no install step required).
"""

import os
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
PKG_ROOT = os.path.dirname(HERE)
sys.path.insert(0, PKG_ROOT)

from guarded_fs.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
